{
  "name": "@pulse/api",
  "version": "1.0.0",
  "description": "Visual uptime monitor — API (Hono + CockroachDB + Sandbox + Object Storage)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node --env-file=.env --import tsx/esm src/db/migrate.ts",
    "worker": "node --env-file=.env --import tsx/esm src/sandbox/worker-entry.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@brimble/sandbox": "^0.1.2",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "hono": "^4.6.14",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
