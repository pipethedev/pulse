# HTTP
PORT=8080

# CockroachDB (Brimble-provisioned). Postgres wire protocol.
DATABASE_URL=postgresql://root@localhost:26257/pulse?sslmode=disable

# Brimble Sandbox SDK
BRIMBLE_SANDBOX_KEY=replace-me

# Brimble Object Storage (S3-compatible)
S3_ENDPOINT=https://<account>.objects.brimble.io
S3_REGION=auto
S3_BUCKET=pulse-screenshots
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# Public base for serving screenshots
PUBLIC_ASSET_BASE_URL=https://pulse-screenshots.objects.brimble.io

# Sandbox tuning
SANDBOX_TEMPLATE=node-22
SANDBOX_REGION=auto

# Worker only
SANDBOX_MODE=one-shot
CHECK_INTERVAL_MINUTES=15
